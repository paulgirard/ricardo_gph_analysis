#Start main estimation
setwd("/Users/youssef/Dropbox/Gold and Trade Project/Replication")
#Model set up
title<-"Model : 1864-1912"
model<-1
###Create SIENA data object
mydata <- sienaDataCreate(Tradepartner_nw, Money_bh,Treaty_nw,
distance_nw,inv_distance_nw,contiguity_nw,contiguity2_nw,language_nw,
GDP,GDPpc,Sharetrade_nw,DebtService,BilateralDisputes_nw,
GoldSilverRatio, OpennessExpCur,OpennessTradePop,OpennessExpCst,OpennessGDPCur,ToT,PolityIV,Latent,GDPshare_nw,
war_nw,CivilWar,extrawar, InterWar,Disputes, GoldProd,SilverProd,MetalRatio,GlobalTrade,htisharewar_nw,ForeignDebt,ForeignDebtshare,
Polit11,Polit10,Polit03,Polit04,Polit01,v2x_polyarchy,v2x_libdem,
v2x_partipdem, v2x_api,v2x_mpi, v2x_suffr,v2xel_frefair,v2x_liberal, v2x_corr,Primaryshare,PrimaryExp_nw,ManuExp_nw,timetrend,France,Germany,USA,nodeSets=list(Nations)
)
print01Report(mydata, modelname = "April25")
##########################################################
##########################################################
myeff<-getEffects(mydata)
#effectsDocumentation(myeff)
############################################
########TRADE NETWORK
#Elementary Network effects
myeff<-includeEffects(myeff, name="Tradepartner_nw" ,density, type="eval")
myeff<-includeEffects(myeff, name="Tradepartner_nw" ,recip, type="eval",include=TRUE)
myeff<-includeEffects(myeff, name="Tradepartner_nw",transTrip, type="eval",include=TRUE)
myeff<-includeEffects(myeff, name="Tradepartner_nw",nbrDist2,type="eval",include=TRUE)
myeff<-includeEffects(myeff, name="Tradepartner_nw",inPop,type="eval",include=FALSE) #To model rich getting richer in ties
myeff<-includeEffects(myeff, name="Tradepartner_nw",inActSqrt,type="eval",include=FALSE) #Not sign, To model higher indegree also sends more, if i import more i export more
myeff<-includeEffects(myeff, name="Tradepartner_nw",outPopSqrt,type="eval",include=FALSE) #to model reverse
myeff<-includeEffects(myeff, name="Tradepartner_nw",inPopSqrt,type="eval",include=TRUE)
######################behaviour effects on network
myeff<-includeEffects(myeff,egoX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=FALSE)
myeff<-includeEffects(myeff,altX,sameX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=FALSE)
myeff<-includeEffects(myeff,absDiffX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=TRUE)
myeff<-includeEffects(myeff,diffX,name="Tradepartner_nw",interaction1="Money_bh",type="eval",include=TRUE)
myeff<-includeEffects(myeff,egoDiffX,name="Tradepartner_nw",interaction1="Money_bh",type="eval",include=TRUE)
myeff<-includeEffects(myeff,diffSqX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=FALSE) #test homophily
myeff<-includeEffects(myeff,altSqX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=FALSE) #conformity to normative value
myeff<-includeEffects(myeff,altX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=FALSE)#Test aspiration (weak definition for centered V)
myeff<-includeEffects(myeff,egoX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=TRUE)#Sociability
myeff<-includeEffects(myeff,egoSqX,name="Tradepartner_nw",interaction1="Money_bh", type="eval",include=FALSE)#Sociability
######################Covariates
myeff<- includeEffects(myeff,X, name="Tradepartner_nw",interaction1="distance_nw",type="eval",include=TRUE)
myeff<- includeEffects(myeff,X, name="Tradepartner_nw",interaction1="contiguity_nw",type="eval",include=TRUE)
myeff<- includeEffects(myeff,X, name="Tradepartner_nw",interaction1="language_nw",type="eval",include=TRUE)
myeff<- includeEffects(myeff,egoX,altX, name="Tradepartner_nw",interaction1="GDP",type="eval",include=TRUE)
myeff<- includeEffects(myeff,X, name="Tradepartner_nw",interaction1="BilateralDisputes_nw",type="eval",include=FALSE)
myeff<- includeEffects(myeff,X, name="Tradepartner_nw",interaction1="PrimaryExp_nw",type="eval",include=FALSE)
myeff<-includeEffects(myeff,egoX,name="Tradepartner_nw",interaction1="ToT", type="eval",include=FALSE)
myeff<- includeEffects(myeff,X, name="Tradepartner_nw",interaction1="Treaty_nw",type="eval",include=FALSE)
#############################
##time dummies for network part
myeff <- includeEffects(myeff, egoX, interaction1='time1',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time2',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time3',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time4',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time5',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time6',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time7',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time8',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time9',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time10',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time11',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time12',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time13',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='time14',include = FALSE)
myeff <- includeEffects(myeff, egoX, interaction1='timetrend',include = TRUE)
