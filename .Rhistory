result <- gph_regions %>%
left_join(gph_wide, by = "GPH_code")
View(result)
write.csv(result,
"gph_with_AndersonNorheim_regions_and_periods.csv",
row.names = FALSE)
rm(list = ls(all = TRUE))
gc()
