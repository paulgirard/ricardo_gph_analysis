dossier <- here("Pair_blocs_Intramax")
for (year in 1833:1938) {
message("Annee ", year)
res <- tryCatch(traiter_annee(year, dossier),
error = function(e) { message("  ERREUR ", year, " : ", conditionMessage(e)); NULL })
}
