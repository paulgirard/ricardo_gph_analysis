gph_regions         <- gph_regions[as.character(gph_regions$GPH_code) %in% codes_gardes, ]
gphentitiesovertime <- gphentitiesovertime[
as.character(gphentitiesovertime$GPH_code) %in% codes_gardes, ]
# --- 2. Construire la colonne combinée "period | status | sovereign" ---
gph_long <- gphentitiesovertime %>%
mutate(
period = paste0(
ifelse(is.na(start_year) | start_year == "", "?", start_year),
"-",
ifelse(is.na(end_year)   | end_year   == "", "?", end_year)
),
period_info = paste(period, GPH_status, sovereign_GPH_code, sep = " | "),
start_year_num = suppressWarnings(as.numeric(start_year))
) %>%
arrange(GPH_code, start_year_num) %>%
group_by(GPH_code) %>%
mutate(period_num = row_number()) %>%
ungroup() %>%
select(GPH_code, period_num, period_info)
rm(list = ls(all = TRUE))
