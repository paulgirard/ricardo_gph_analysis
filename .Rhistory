library(dplyr)
library(readxl)
library(tidyverse)
library(tidyr)
library(ggplot2)
setwd("~/Desktop/ricardo_gph_analysis")
#Look at entities in Intramax and Louvain
annees <- 1833:1938
entites <- data.frame(gph = character(), nom = character(), stringsAsFactors = FALSE)
# ---- INTRAMAX : exporterId/importerId = codes GPH, exportateur/importateur = noms ----
for (year in annees) {
f <- paste0("data/blocks/Intramax/paires_blocs_", year, ".csv")
if (!file.exists(f) || file.info(f)$size == 0) next
d <- read.csv(f, stringsAsFactors = FALSE)
d <- d[!is.na(d$value), ]                      # <-- garder seulement les flux reels
if (nrow(d) == 0) next
exp <- data.frame(gph = as.character(d$exporterId), nom = as.character(d$exportateur))
imp <- data.frame(gph = as.character(d$importerId), nom = as.character(d$importateur))
entites <- rbind(entites, exp, imp)
}
# ---- LOUVAIN : source/target = codes GPH, sourceLabel/targetLabel = noms ----
for (year in annees) {
f <- paste0("data/blocks/louvain/", year, "_fob_enrichi.csv")
if (!file.exists(f) || file.info(f)$size == 0) next
d <- read.csv(f, stringsAsFactors = FALSE)
if (nrow(d) == 0) next
src <- data.frame(gph = as.character(d$source), nom = as.character(d$sourceLabel))
tgt <- data.frame(gph = as.character(d$target), nom = as.character(d$targetLabel))
entites <- rbind(entites, src, tgt)
}
# ---- dedupliquer (garder une ligne par code GPH, avec son nom) ----
entites <- unique(entites)
# faire remonter les versions AVEC nom avant celles sans, puis dedupliquer par code
entites <- entites[order(entites$gph, is.na(entites$nom) | entites$nom == ""), ]
entites <- entites[!duplicated(entites$gph), ]
#In case we want the list of entities used in Intramax and Louvain
#write.csv(entites, "data/entites_intramax_louvain.csv",
#  row.names = FALSE, fileEncoding = "UTF-8")
#####Adding Anderson and Norheim blocs
gph_regions <- read.csv("~/Desktop/gph_with_AndersonNorheim_regions.csv",
stringsAsFactors = FALSE)
gphentitiesovertime <- read.csv("data/GeoPolHist_entities_status_over_time.csv",stringsAsFactors = FALSE)
codes_gardes <- as.character(entites$gph)
gph_regions         <- gph_regions[as.character(gph_regions$GPH_code) %in% codes_gardes, ]
gphentitiesovertime <- gphentitiesovertime[
as.character(gphentitiesovertime$GPH_code) %in% codes_gardes, ]
# --- 2. Construire la colonne period "YYYY-YYYY" ---
gphentitiesovertime <- gphentitiesovertime %>%
mutate(period = paste0(
ifelse(is.na(start_year) | start_year == "", "?", start_year),
"-",
ifelse(is.na(end_year)   | end_year   == "", "?", end_year)
))
gphentitiesovertime <- read.csv("data/GeoPolHist_entities_status_over_time.csv",stringsAsFactors = FALSE)
gphentitiesovertime <- gphentitiesovertime[
as.character(gphentitiesovertime$GPH_code) %in% codes_gardes, ]
# --
gphentitiesovertime <- gphentitiesovertime %>%
mutate(period = paste0(
ifelse(is.na(start_year) | start_year == "", "?", start_year),
"-",
ifelse(is.na(end_year)   | end_year   == "", "?", end_year)
))
View(gphentitiesovertime)
gph_long <- gphentitiesovertime %>%
mutate(start_year_num = suppressWarnings(as.numeric(start_year))) %>%
arrange(GPH_code, start_year_num) %>%
group_by(GPH_code) %>%
mutate(period_num = row_number()) %>%
ungroup() %>%
select(GPH_code, period_num, period, GPH_status, sovereign_GPH_code)
View(gph_long)
gph_wide <- gph_long %>%
pivot_wider(
id_cols     = GPH_code,
names_from  = period_num,
values_from = c(period, GPH_status, sovereign_GPH_code),
names_glue  = "{.value}_{period_num}"
)
View(gph_wide)
gph_regions <- read.csv("~/Desktop/gph_with_AndersonNorheim_regions.csv",
stringsAsFactors = FALSE)
gphentitiesovertime <- read.csv("data/GeoPolHist_entities_status_over_time.csv",stringsAsFactors = FALSE)
codes_gardes <- as.character(entites$gph)
gph_regions         <- gph_regions[as.character(gph_regions$GPH_code) %in% codes_gardes, ]
gphentitiesovertime <- gphentitiesovertime[
as.character(gphentitiesovertime$GPH_code) %in% codes_gardes, ]
# --- 2. Construire la colonne combinée "period | status | sovereign" ---
gph_long <- gphentitiesovertime %>%
mutate(
period = paste0(
ifelse(is.na(start_year) | start_year == "", "?", start_year),
"-",
ifelse(is.na(end_year)   | end_year   == "", "?", end_year)
),
period_info = paste(period, GPH_status, sovereign_GPH_code, sep = " | "),
start_year_num = suppressWarnings(as.numeric(start_year))
) %>%
arrange(GPH_code, start_year_num) %>%
group_by(GPH_code) %>%
mutate(period_num = row_number()) %>%
ungroup() %>%
select(GPH_code, period_num, period_info)
rm(list = ls(all = TRUE))
gc()
